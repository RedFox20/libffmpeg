exec_prefix=${prefix}
libdir=/home/jorma/krattcam/packages/libffmpeg/libffmpeg/imx8mp/lib
includedir=/home/jorma/krattcam/packages/libffmpeg/libffmpeg/imx8mp/include

Name: libavdevice
Description: FFmpeg device handling library
Version: 62.1.100
Requires: 
Requires.private: libavfilter >= 11.4.100, libswscale >= 9.1.100, libavformat >= 62.3.101, libavcodec >= 62.11.100, libswresample >= 6.1.100, libavutil >= 60.8.100
Conflicts:
